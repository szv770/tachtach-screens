{
  "name": "tachtach-screens",
  "version": "1.0.0",
  "type": "module",
  "description": "Digital signage system for Jewish schools — zmanim, limudim, Hayom Yom, and admin messaging on Raspberry Pi 5",
  "main": "server.js",
  "scripts": {
    "dev": "concurrently \"node server.js\" \"vite\"",
    "dev:watch": "concurrently \"node server.js\" \"vite build --watch\"",
    "dev:server": "node server.js",
    "dev:client": "vite",
    "build": "vite build",
    "start": "node server.js",
    "setup": "node setup.js",
    "reset-admin": "node scripts/reset-admin-credentials.js"
  },
  "dependencies": {
    "bcrypt": "^5.1.1",
    "cheerio": "^1.0.0",
    "cookie-parser": "^1.4.6",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^7.4.1",
    "fast-xml-parser": "^5.10.1",
    "framer-motion": "^11.11.0",
    "multer": "^1.4.5-lts.1",
    "node-fetch": "^3.3.2",
    "node-schedule": "^2.1.1",
    "otplib": "^12.0.1",
    "puppeteer-core": "^25.3.0",
    "qrcode": "^1.5.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "sharp": "^0.33.5",
    "uuid": "^14.0.1"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.0",
    "vite": "^6.0.0"
  }
}
